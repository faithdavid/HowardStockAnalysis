# ── Airtable ──────────────────────────────────────────────────────────────────
# Create a Personal Access Token at https://airtable.com/create/tokens
AIRTABLE_TOKEN=your_airtable_pat_here
AIRTABLE_BASE_ID=your_base_id_here

# Airtable Table Names (must match EXACTLY as they appear in Airtable UI)
AIRTABLE_TABLE_INSIDER=Raw Insider Data
AIRTABLE_TABLE_MARKET=Market Pulls
AIRTABLE_TABLE_QUALIFIED=Filtered/Qualified Insider List
AIRTABLE_TABLE_TECH_5=Technical Scans Under $5 CAD
AIRTABLE_TABLE_TECH_10=Technical Scans Under $10 CAD
AIRTABLE_TABLE_TECH_20=Technical Scans Under $20 CAD
AIRTABLE_TABLE_BACKTEST=Historical/Backtest
AIRTABLE_TABLE_ALERTS=Alert History
AIRTABLE_TABLE_RUNS=Run Reports

# ── Polygon.io ────────────────────────────────────────────────────────────────
# Free tier API key from https://polygon.io
POLYGON_API_KEY=your_polygon_key_here

# ── Zapier ────────────────────────────────────────────────────────────────────
# Zapier webhook URL from your "Catch Hook" trigger
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/

# ── Alerts ────────────────────────────────────────────────────────────────────
ALERT_EMAIL_TO=your_email@example.com

# ── Pipeline Settings ─────────────────────────────────────────────────────────
MIN_SCORE_FOR_ALERT=85
USE_ZAPIER=true
MIN_SCAN_SCORE=59
V1_ATR_MIN=3.5
REPEAT_BUY_DAYS=30
V1_VOL_MIN_M=30
MIN_VOLUME_SHARES=50000
V1_VOL_MAX_M=100
V2_VOL_MAX_M=10000
V2_ATR_MAX=20.0
V2_ATR_MIN=7.0
V2_VOL_MIN_M=30

# ── Railway / Security ────────────────────────────────────────────────────────
# Protect the /run endpoint from unauthorized triggers
RUN_SECRET=choose_a_strong_secret_here

# ── Frontend ─────────────────────────────────────────────────────────────────
# Set this on your Railway frontend service to point to your backend URL
NUXT_PUBLIC_API_BASE=https://your-backend-service.railway.app
